# ============================================================
# GreenLight AI — environment variables
# Copy this file to .env and fill in real values.
# .env is gitignored. Never commit secrets.
# ============================================================

# ----- LLM provider keys -----

# Google Gemini (free forever, 1500 RPD)
# Get a key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=replace-me

# Groq (free forever, 1K RPD per model)
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=replace-me

# Featherless AI (3-day trial, 100K output tokens)
# Sign up with promo code BOA26: https://featherless.ai
FEATHERLESS_API_KEY=replace-me

# ----- Band platform -----

# WebSocket and REST endpoints (defaults shown)
BAND_WS_URL=wss://ws.band.ai
BAND_REST_URL=https://api.band.ai

# Legacy var names used by some SDK versions — set both
THENVOI_WS_URL=wss://ws.band.ai
THENVOI_REST_URL=https://api.band.ai

# Legacy single-room ID. Used as a fallback when breakout vars are unset.
GREENLIGHT_ROOM_ID=replace-me-with-band-room-id

# Breakout rooms — Phase-isolated architecture.
# Leave blank to run in single-room (legacy) mode.
BRIEFING_ROOM_ID=
CROSS_EXAM_ROOM_ID=
VERDICT_ROOM_ID=

# A human user's API key used by the orchestrator/frontend to post messages
ORCHESTRATOR_API_KEY=replace-me-with-band-user-api-key

# ----- Mode toggle -----

# "dev"   = all agents route through Gemini (saves Featherless tokens)
# "demo"  = each agent uses its assigned provider per blueprint addendum FIX 8
LLM_MODE=dev
